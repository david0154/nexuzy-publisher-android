<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Custom Toolbar with David AI branding -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDavidAi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="David AI"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by Nexuzy Lab"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"/>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Online status bar -->
    <TextView
        android:id="@+id/tvStatusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="\u25CF  David AI is online"
        android:textColor="#2E7D32"
        android:textSize="11sp"
        android:background="#E8F5E9"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarDavidAi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Chat messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvStatusBar"
        app:layout_constraintBottom_toTopOf="@id/tvTyping"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Typing indicator -->
    <TextView
        android:id="@+id/tvTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="David AI is thinking\u2026"
        android:textSize="12sp"
        android:textColor="#888888"
        android:textStyle="italic"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dividerInput"/>

    <!-- Divider above input -->
    <View
        android:id="@+id/dividerInput"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toTopOf="@id/inputRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Input row -->
    <LinearLayout
        android:id="@+id/inputRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask David AI anything\u2026"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:minHeight="48dp"
            android:background="@android:color/transparent"
            android:textSize="15sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:imeOptions="actionSend"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="Send"
            android:textAllCaps="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
