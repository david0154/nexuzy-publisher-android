<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/design_default_color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Stats card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Overview"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTotalArticles"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total articles: 0"
                        android:textSize="13sp"
                        tools:text="Total articles: 5" />

                    <TextView
                        android:id="@+id/tvDraftArticles"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Drafts: 0"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvPublishedArticles"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Published: 0"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTotalFeeds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Configured RSS feeds: 0"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fetch progress bar -->
        <ProgressBar
            android:id="@+id/fetchProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="8dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- Empty state hint -->
        <TextView
            android:id="@+id/tvNoNewsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👆 Go to RSS tab, add feeds, then tap Fetch Latest News"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textColor="#888888"
            android:padding="24dp"
            android:visibility="visible" />

        <!-- Section: Latest News -->
        <LinearLayout
            android:id="@+id/sectionLatest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐 Latest News"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_news" />
        </LinearLayout>

        <!-- Section: Hot News -->
        <LinearLayout
            android:id="@+id/sectionHot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Hot News"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHotNews"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="horizontal"
                tools:listitem="@layout/item_news" />
        </LinearLayout>

        <!-- Section: Potential Viral -->
        <LinearLayout
            android:id="@+id/sectionViral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀 Potential Viral"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvViralNews"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="horizontal"
                tools:listitem="@layout/item_news" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
